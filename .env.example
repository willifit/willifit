# Copy this file to `.env` (same directory) and fill in your real keys.
# The .env file is git-ignored so your keys never commit to the repo.
#
#   cp .env.example .env
#   # then edit .env and paste your actual keys
#
# After that, every verification / audit script just works.  You never
# have to `export ANTHROPIC_API_KEY=...` again after opening a new
# terminal -- the scripts auto-load from .env at startup.
#
# If you also `export KEY=value` in your shell before running, the shell
# value wins -- .env is fallback, not override.

# Anthropic (Claude Vision) -- get one at https://console.anthropic.com/settings/keys
# Used by auto_verify.py, streetview_verify.py, website_verify.py
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# Google Maps Platform -- any key with Street View Static + Geocoding + Places
# enabled.  For CLI scripts, use a key with NO HTTP-referrer restrictions
# (server-side API calls don't send a Referer header).  See the comment in
# willifit.html next to GOOGLE_MAPS_API_KEY for the security model.
GOOGLE_MAPS_API_KEY=AIzaSy_REPLACE_ME
